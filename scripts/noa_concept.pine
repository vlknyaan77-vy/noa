//@version=6
indicator("N/O-A Concept (2026 Version)", overlay = true, max_boxes_count = 500, max_lines_count = 500, max_labels_count = 500)

// ==========================================
// 1. TIMEFRAME CHECK
// ==========================================
// H1 and below are excluded. H4, D, W, M are active.
is_valid_tf = not timeframe.isintraday or timeframe.multiplier > 60
if not is_valid_tf
    runtime.error("N/O-A Concept is only valid for H4 and higher timeframes. H1 and below are excluded.")

// ==========================================
// 2. DATA STRUCTURES (UDT)
// ==========================================

// Module Type Enum-like flags
type ModuleInfo
    float top
    float bottom
    int start_index
    string mod_type // "M1", "M2", "M3", "M4"
    int strength
    bool is_active = true

type Area
    float start_price
    float end_price
    int start_index
    int end_index
    bool is_bullish
    float strength_score = 0.0
    int module_flags = 0
    float fib_0 = 0.0
    float fib_15 = 0.0
    float fib_25 = 0.0
    float fib_38 = 0.0
    float fib_50 = 0.0
    float fib_100 = 0.0
    ModuleInfo[] modules

// Initialize arrays to store areas
var Area[] area_history = array.new<Area>()
var Area active_area = na

method update_fibs(Area self) =>
    diff = math.abs(self.start_price - self.end_price)
    self.fib_0 := self.start_price
    self.fib_100 := self.end_price
    mult = self.is_bullish ? 1 : -1
    self.fib_15 := self.start_price + diff * 0.15 * mult
    self.fib_25 := self.start_price + diff * 0.25 * mult
    self.fib_38 := self.start_price + diff * 0.38 * mult
    self.fib_50 := self.start_price + diff * 0.50 * mult

// ==========================================
// 3. GLOBAL INPUTS
// ==========================================
group "General Settings"
    int pivot_leg_min = input.int(7, "Min Pivot Leg Bars", minval = 1)
    string dxy_symbol = input.symbol("TVC:DXY", "DXY Symbol")

group "Visual Settings"
    color bull_area_color = input.color(color.new(color.blue, 90), "Bullish Area Color")
    color bear_area_color = input.color(color.new(color.red, 90), "Bearish Area Color")
    bool show_tp_sl = input.bool(true, "Show TP/SL Levels")

// ==========================================
// 5. MODULE DETECTION ALGORITHMS
// ==========================================

// M1 Detection Logic: Extreme candle with max 1 overlap
detect_m1(Area a) =>
    int extreme_idx = a.start_index
    // In N/O-A, M1 is at the very beginning of the new area (the pivot point)
    float extreme_high = high[bar_index - extreme_idx]
    float extreme_low = low[bar_index - extreme_idx]

    // Overlap check: look at subsequent candles
    overlap_count = 0
    for i = 1 to 10
        idx = extreme_idx + i
        if idx > a.end_index
            break
        curr_h = high[bar_index - idx]
        curr_l = low[bar_index - idx]
        // Does this candle overlap the extreme candle's range?
        if curr_h > extreme_low and curr_l < extreme_high
            overlap_count += 1

    if overlap_count <= 1
        ModuleInfo.new(extreme_high, extreme_low, extreme_idx, "M1", 3)
    else
        na

// M2 Detection Logic: Wick Imbalance
detect_m2(Area a) =>
    ModuleInfo[] m2_list = array.new<ModuleInfo>()
    for i = a.start_index to a.start_index + 5 // Check near the start
        h = high[bar_index - i]
        l = low[bar_index - i]
        o = open[bar_index - i]
        c = close[bar_index - i]
        body = math.abs(o - c)
        top_wick = h - math.max(o, c)
        bot_wick = math.min(o, c) - l

        if top_wick > body * 1.5 or bot_wick > body * 1.5
            m2_list.push(ModuleInfo.new(h, l, i, "M2", 2))
    m2_list

// M4 Detection Logic: R.O.P (Breaker)
// A-B-C pattern: A=pivot, B=pullback, C=sweep, then break B
detect_m4(Area a) =>
    ModuleInfo res = na
    if a.end_index - a.start_index > 10
        for i = a.start_index + 2 to a.end_index - 5
            h_b = high[bar_index - i]
            l_b = low[bar_index - i]

            // Look for sweep and break
            has_sweep = false
            sweep_idx = 0
            for j = i + 1 to a.end_index
                h_j = high[bar_index - j]
                l_j = low[bar_index - j]
                if a.is_bullish
                    if l_j < l_b
                        has_sweep := true
                        sweep_idx := j
                        break
                else
                    if h_j > h_b
                        has_sweep := true
                        sweep_idx := j
                        break

            if has_sweep
                has_break = false
                for k = sweep_idx + 1 to a.end_index
                    c_k = close[bar_index - k]
                    if a.is_bullish
                        if c_k > h_b
                            has_break := true
                            break
                    else
                        if c_k < l_b
                            has_break := true
                            break

                if has_break
                    res := ModuleInfo.new(h_b, l_b, i, "M4", 0)
                    break
    res

// M3 Detection Logic: FVG
detect_m3(Area a) =>
    ModuleInfo[] m3_list = array.new<ModuleInfo>()
    if a.end_index - a.start_index >= 3
        for i = a.start_index to a.end_index - 2
            // Pine Script indexing is relative to current bar.
            // We need to convert bar_index 'i' to relative index.
            idx1 = bar_index - i
            idx3 = bar_index - (i + 2)

            h1 = high[idx1]
            l1 = low[idx1]
            h3 = high[idx3]
            l3 = low[idx3]

            if a.is_bullish and l3 > h1
                m3_list.push(ModuleInfo.new(l3, h1, i + 1, "M3", 1))
            else if not a.is_bullish and h3 < l1
                m3_list.push(ModuleInfo.new(l1, h3, i + 1, "M3", 1))
    m3_list

// ==========================================
// 4. SWING AND AREA DETECTION
// ==========================================

ph = ta.pivothigh(5, 5)
pl = ta.pivotlow(5, 5)

var int last_p_idx = 0
var float last_p_price = 0.0
var bool last_p_is_high = false

if not na(ph) or not na(pl)
    curr_p_is_high = not na(ph)
    curr_p_price = curr_p_is_high ? ph : pl
    curr_p_idx = bar_index - 5

    if last_p_idx != 0
        leg_len = curr_p_idx - last_p_idx
        if leg_len >= pivot_leg_min and curr_p_is_high != last_p_is_high
            can_create_new = false
            if not na(active_area)
                is_reversal = (active_area.is_bullish and not curr_p_is_high) or (not active_area.is_bullish and curr_p_is_high)

                if is_reversal
                    reached_50 = active_area.is_bullish ? curr_p_price <= active_area.fib_50 : curr_p_price >= active_area.fib_50
                    if reached_50
                        can_create_new := true
                else
                    // Extension of same trend - update end_price
                    active_area.end_price := curr_p_price
                    active_area.end_index := curr_p_idx
                    active_area.update_fibs()
            else
                can_create_new := true

            if can_create_new
                if not na(active_area)
                    area_history.push(active_area)

                active_area := Area.new(
                  start_price = last_p_price,
                  end_price = curr_p_price,
                  start_index = last_p_idx,
                  end_index = curr_p_idx,
                  is_bullish = curr_p_price > last_p_price,
                  modules = array.new<ModuleInfo>()
                )
                active_area.update_fibs()

                // Detect Modules for the new area
                m1 = detect_m1(active_area)
                if not na(m1)
                    active_area.modules.push(m1)

                m2s = detect_m2(active_area)
                for m in m2s
                    active_area.modules.push(m)

                m3s = detect_m3(active_area)
                for m in m3s
                    active_area.modules.push(m)

                m4 = detect_m4(active_area)
                if not na(m4)
                    active_area.modules.push(m4)

    last_p_idx := curr_p_idx
    last_p_price := curr_p_price
    last_p_is_high := curr_p_is_high

// ==========================================
// 8. ALERTS
// ==========================================

alert_msg(string type, float score, bool risky) =>
    "N/O-A " + type + " Setup Detected!\nScore: " + str.tostring(score) + "\n" + (risky ? "WARNING: 70+ Bars distance." : "Direct Action (Eylem 1) possible.")

// ==========================================
// 7. SCORING AND DXY CORRELATION
// ==========================================

// Fetch DXY data
[dxy_c, dxy_o, dxy_h, dxy_l] = request.security(dxy_symbol, timeframe.period, [close, open, high, low])
dxy_bullish = dxy_c > dxy_o
// Refined DXY trend check
dxy_trend_bullish = ta.sma(dxy_c, 10) > ta.sma(dxy_c, 20)

calculate_score(Area a, ModuleInfo m, bool dxy_bull) =>
    float score = 0.0

    // Timeframe Score
    if timeframe.isweekly or timeframe.ismonthly
        score += 4
    else if timeframe.isdaily
        score += 3
    else
        score += 2

    // Module Type Score
    score += m.strength

    // Layer Score (0-0.25 is Katman 1)
    // Check if module is within Katman 1
    is_katman1 = false
    if a.is_bullish
        is_katman1 := m.bottom <= a.fib_25
    else
        is_katman1 := m.top >= a.fib_25

    if is_katman1
        score += 2

    // Energy Filling
    if check_energy_filling(a)
        score += 1

    // DXY Correlation Penalty
    // For EURUSD (bullish), DXY trend should be bearish
    // Use trend for more stability
    correlation_ok = a.is_bullish ? not dxy_bull : dxy_bull
    if not correlation_ok
        score -= 2

    score

// ==========================================
// 6. DISTANCE AND ENERGY LOGIC
// ==========================================

check_energy_filling(Area a) =>
    // Check for counter-trend pullbacks in 0-0.15/0.25 range
    // Look at the last 20 bars of the area
    pullback_found = false
    for i = 0 to 20
        idx = a.end_index - i
        if idx < a.start_index
            break
        o = open[bar_index - idx]
        c = close[bar_index - idx]
        is_red = a.is_bullish ? c < o : c > o
        if is_red
            pullback_found := true
            break
    pullback_found

// VISUALIZATION FOR AREAS AND MODULES
var box[] all_boxes = array.new<box>()
var line[] all_lines = array.new<line>()
var label[] all_labels = array.new<label>()

cleanup_ui() =>
    if array.size(all_boxes) > 20
        box.delete(array.shift(all_boxes))
    if array.size(all_lines) > 20
        line.delete(array.shift(all_lines))
    if array.size(all_labels) > 20
        label.delete(array.shift(all_labels))

if not na(active_area)
    if bar_index == active_area.end_index + 5 // Just when detected
        cleanup_ui()
        b = box.new(active_area.start_index, active_area.start_price, active_area.end_index, active_area.end_price,
          bgcolor = active_area.is_bullish ? bull_area_color : bear_area_color,
          border_color = active_area.is_bullish ? color.blue : color.red)

        all_boxes.push(b)

        // Draw Fib Levels
        l50 = line.new(active_area.start_index, active_area.fib_50, active_area.end_index, active_area.fib_50, color=color.gray, style=line.style_dashed)
        all_lines.push(l50)

        if show_tp_sl
            // SL is usually outside Katman 1 (0.25) or Area Start (0)
            sl_price = active_area.start_price
            lsl = line.new(active_area.end_index, sl_price, active_area.end_index + 20, sl_price, color=color.red, width=2, style=line.style_solid)
            lbsl = label.new(active_area.end_index + 20, sl_price, "SL", color=color.red, textcolor=color.white, style=label.style_label_left)
            all_lines.push(lsl)
            all_labels.push(lbsl)

        // Draw Modules
        for mod in active_area.modules
            // 70 Bar Rule check
            distance = bar_index - mod.start_index
            is_risky = distance >= 70

            score = calculate_score(active_area, mod, dxy_trend_bullish)
            setup_type = score >= 9 ? "S+" : score >= 7 ? "A+" : "B"

            mb = box.new(mod.start_index, mod.top, active_area.end_index, mod.bottom,
              bgcolor = setup_type == "S+" ? color.new(color.green, 70) : setup_type == "A+" ? color.new(color.yellow, 70) : color.new(color.gray, 80),
              border_color = setup_type == "S+" ? color.green : setup_type == "A+" ? color.yellow : color.gray,
              text = mod.mod_type + " " + setup_type + " (" + str.tostring(score) + "p)" + (is_risky ? "\n70+ Bars" : ""))
            all_boxes.push(mb)

            if setup_type == "S+" or setup_type == "A+"
                alert(alert_msg(setup_type, score, is_risky), alert.freq_once_per_bar_close)
